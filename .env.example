# Copy this file to .env.local for local dev. On Vercel, set the same vars
# in Project Settings -> Environment Variables (production + preview + dev).
#
# Anon key is safe to expose in the browser; RLS policies in supabase/schema.sql
# control what it can actually do. NEVER paste a service_role key into any
# VITE_* var — it would be shipped to the client.

VITE_SUPABASE_URL=https://splthfrwtddrkcherwwj.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional — only needed for the tldraw whiteboard module
VITE_TLDRAW_LICENSE_KEY=

# Optional — OpenRouter API key for built-in AI (users can also paste
# their own in Settings -> AI)
VITE_OPENROUTER_API_KEY=
